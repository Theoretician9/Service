        "question": "Откуда будем искать клиентов?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "source_content",
        "label": "Текст для анализа",
        "type": "text",
        "required": true,
        "max_length": 5000,
        "question": "Вставь текст для анализа (до 5000 символов)",
        "hint": null,
        "condition": {"field": "lead_source", "value": "Вставлю текст комментариев"},
        "extract_from_free_text": false
      },
      {
        "id": "search_query",
        "label": "Поисковый запрос",
        "type": "text",
        "required": true,
        "max_length": 300,
        "question": "По какому запросу искать?",
        "hint": null,
        "condition": {"field": "lead_source", "value": "Искать в публичных источниках"},
        "extract_from_free_text": true
      },
      {
        "id": "target_persona",
        "label": "Идеальный клиент",
        "type": "text",
        "required": false,
        "max_length": 300,
        "question": "Опиши идеального клиента: кого именно ищем",
        "hint": null,
        "extract_from_free_text": true
      }
    ]
  },
  "question_plan": [
    {"field_id": "product_offer", "step": 1, "condition": null},
    {"field_id": "lead_source", "step": 2, "condition": null},
    {"field_id": "source_content", "step": 3, "condition": {"field": "lead_source", "value": "Вставлю текст комментариев"}},
    {"field_id": "search_query", "step": 4, "condition": {"field": "lead_source", "value": "Искать в публичных источниках"}},
    {"field_id": "target_persona", "step": 5, "condition": null}
  ],
