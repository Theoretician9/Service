{
  "id": "niche_selection",
  "schema_version": "1.0",
  "name": "Выбор ниши",
  "emoji": "🔍",
  "description": "Подберу 10 ниш на основе твоего опыта, интересов и окружения",
  "credit_cost": 2,
  "available_on_free": true,
  "mode": "standard",
  "llm_config": {
    "slot_filling_provider": "anthropic",
    "slot_filling_model": "claude-haiku-4-5",
    "generation_provider": "anthropic",
    "generation_model": "claude-sonnet-4-5"
  },
  "tools": ["web_search", "google_sheets", "pdf_gen"],
  "tools_require_paid": ["google_sheets"],
  "input_schema": {
    "fields": [
      {
        "id": "geography",
        "label": "География",
        "type": "choice",
        "required": true,
        "choices": ["Россия", "Казахстан", "Беларусь", "Весь СНГ"],
        "question": "Где планируешь работать/продавать?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "available_capital",
        "label": "Стартовый капитал",
        "type": "choice",
        "required": true,
        "choices": ["до 50 тыс.", "50–200 тыс.", "200–500 тыс.", "500 тыс.+"],
        "question": "Какой стартовый капитал готов вложить?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "work_history",
        "label": "Все работы за 10 лет",
        "type": "text",
        "required": true,
        "max_length": 500,
        "question": "Перечисли ВСЕ свои работы и занятия за последние 10 лет — даже те, которые кажутся неважными. Каждая работа, подработка, хобби которое приносило деньги. Это критически важно для подбора ниш.",
        "hint": null,
        "extract_from_free_text": true
      },
      {
        "id": "environment_requests",
        "label": "Запросы окружения",
        "type": "text",
        "required": true,
        "max_length": 300,
        "question": "Что тебя чаще всего просят сделать друзья, родственники, знакомые?",
        "hint": null,
        "extract_from_free_text": true
      },
      {
        "id": "personal_interest",
        "label": "Личный интерес",
        "type": "text",
        "required": true,
        "max_length": 300,
        "question": "Что тебе самому нравится делать? Где время летит незаметно?",
        "hint": null,
        "extract_from_free_text": true
      },
      {
        "id": "social_capital",
        "label": "Социальный капитал",
        "type": "text",
        "required": true,
        "max_length": 300,
        "question": "Чем занимаются люди вокруг тебя — друзья, родственники? Какой бизнес, какие профессии?",
        "hint": null,
        "extract_from_free_text": true
      },
      {
        "id": "format",
        "label": "Формат",
        "type": "multi_choice",
        "required": true,
        "choices": ["Товары", "Услуги", "Инфопродукты", "Всё рассмотреть"],
        "question": "Интересный формат?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "channels",
        "label": "Каналы",
        "type": "multi_choice",
        "required": true,
        "choices": ["Маркетплейсы", "Соцсети", "Telegram", "Офлайн", "Всё"],
        "question": "Предпочтительные каналы продаж?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "available_time",
        "label": "Доступное время",
        "type": "choice",
        "required": true,
        "choices": ["до 10 ч/нед", "10-20 ч/нед", "20-40 ч/нед", "Полный фокус"],
        "question": "Сколько времени готов уделять?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "priority",
        "label": "Приоритет",
        "type": "choice",
        "required": true,
        "choices": ["Быстрые деньги", "Высокий чек", "Баланс"],
        "question": "Что важнее?",
        "hint": null,
        "extract_from_free_text": false
      }
    ]
  },
  "question_plan": [
    {"field_id": "geography", "step": 1, "condition": null},
    {"field_id": "available_capital", "step": 2, "condition": null},
    {"field_id": "work_history", "step": 3, "condition": null},
    {"field_id": "environment_requests", "step": 4, "condition": null},
    {"field_id": "personal_interest", "step": 5, "condition": null},
    {"field_id": "social_capital", "step": 6, "condition": null},
    {"field_id": "format", "step": 7, "condition": null},
    {"field_id": "channels", "step": 8, "condition": null},
    {"field_id": "available_time", "step": 9, "condition": null},
    {"field_id": "priority", "step": 10, "condition": null}
  ],
  "output_schema": {
    "version": "1.0",
    "artifact_type": "niche_table",
    "fields": ["top_niches", "extra_niches", "niches", "recommendation", "recommended_niche", "search_data_used", "assumptions"]
  },
  "project_fields_mapping": {
    "niche_candidates": "niches",
    "chosen_niche": "recommended_niche",
    "hypothesis_table": "niches[*].decomposition",
    "geography": "geography",
    "budget_range": "available_capital",
    "business_model": "format"
  },
  "test_cases": [
    {
      "input": {"geography": "Россия", "available_capital": "50–200 тыс.", "work_history": "5 лет в digital-маркетинге", "environment_requests": "настроить рекламу, сделать сайт", "personal_interest": "фотография, путешествия", "social_capital": "друзья в IT и ресторанном бизнесе", "format": ["Услуги"], "channels": ["Соцсети", "Telegram"], "available_time": "20-40 ч/нед", "priority": "Баланс"},
      "expected_artifact_type": "niche_table",
      "expected_fields": ["top_niches", "extra_niches", "niches", "recommendation", "recommended_niche"]
    }
  ]
}
