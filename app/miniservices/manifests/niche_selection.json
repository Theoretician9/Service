{
  "id": "niche_selection",
  "schema_version": "1.0",
  "name": "Выбор ниши",
  "emoji": "🔍",
  "description": "Подберу 3 ниши с оценкой, числовой моделью и рекомендацией лучшей",
  "credit_cost": 2,
  "available_on_free": true,
  "mode": "standard",
  "llm_config": {
    "slot_filling_provider": "anthropic",
    "slot_filling_model": "claude-haiku-4-5",
    "generation_provider": "anthropic",
    "generation_model": "claude-sonnet-4-5"
  },
  "tools": ["web_search", "google_sheets", "pdf_gen"],
  "tools_require_paid": ["google_sheets"],
  "input_schema": {
    "fields": [
      {
        "id": "geography",
        "label": "География",
        "type": "choice",
        "required": true,
        "choices": ["Россия", "Казахстан", "Беларусь", "Весь СНГ"],
        "question": "Где планируешь продавать?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "available_capital",
        "label": "Стартовый капитал",
        "type": "choice",
        "required": true,
        "choices": ["до 50 тыс.", "50–200 тыс.", "200–500 тыс.", "500 тыс.+"],
        "question": "Стартовый капитал?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "competencies",
        "label": "Компетенции",
        "type": "text",
        "required": true,
        "max_length": 300,
        "question": "Что умеешь? В каких сферах есть опыт или интерес?",
        "hint": null,
        "extract_from_free_text": true
      },
      {
        "id": "format",
        "label": "Формат",
        "type": "multi_choice",
        "required": true,
        "choices": ["Товары", "Услуги", "Инфопродукты", "Всё рассмотреть"],
        "question": "Интересный формат?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "channels",
        "label": "Каналы",
        "type": "multi_choice",
        "required": true,
        "choices": ["Маркетплейсы", "Соцсети", "Telegram", "Офлайн", "Всё"],
        "question": "Предпочтительные каналы продаж?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "target_margin",
        "label": "Маржинальность",
        "type": "choice",
        "required": false,
        "choices": ["до 20%", "20–40%", "40%+"],
        "question": "Желаемая маржинальность?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "operations_readiness",
        "label": "Готовность к операционке",
        "type": "yes_no",
        "required": false,
        "question": "Готов к высокой операционной нагрузке (склад, логистика)?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "practical_experience",
        "label": "Практический опыт",
        "type": "text",
        "required": true,
        "max_length": 500,
        "question": "На чём ты зарабатывал последние 5-10 лет? Какой опыт?",
        "hint": null,
        "extract_from_free_text": true
      },
      {
        "id": "environment_requests",
        "label": "Запросы окружения",
        "type": "text",
        "required": false,
        "max_length": 300,
        "question": "Что тебя чаще всего просят сделать друзья/знакомые?",
        "hint": null,
        "extract_from_free_text": true
      },
      {
        "id": "personal_interest",
        "label": "Личный интерес",
        "type": "text",
        "required": false,
        "max_length": 300,
        "question": "Что тебе самому нравится делать?",
        "hint": null,
        "extract_from_free_text": true
      },
      {
        "id": "social_capital",
        "label": "Социальный капитал",
        "type": "text",
        "required": false,
        "max_length": 300,
        "question": "Чем занимаются люди вокруг тебя? Есть ли полезные связи?",
        "hint": null,
        "extract_from_free_text": true
      },
      {
        "id": "ai_interest",
        "label": "Интерес к AI",
        "type": "yes_no",
        "required": false,
        "question": "Интересны ли тебе нейросети, AI, автоматизация?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "available_time",
        "label": "Доступное время",
        "type": "choice",
        "required": true,
        "choices": ["до 10 ч/нед", "10-20 ч/нед", "20-40 ч/нед", "Полный фокус"],
        "question": "Сколько времени готов уделять?",
        "hint": null,
        "extract_from_free_text": false
      },
      {
        "id": "priority",
        "label": "Приоритет",
        "type": "choice",
        "required": true,
        "choices": ["Быстрые деньги", "Высокий чек", "Баланс"],
        "question": "Что важнее?",
        "hint": null,
        "extract_from_free_text": false
      }
    ]
  },
  "question_plan": [
    {"field_id": "geography", "step": 1, "condition": null},
    {"field_id": "available_capital", "step": 2, "condition": null},
    {"field_id": "competencies", "step": 3, "condition": null},
    {"field_id": "practical_experience", "step": 4, "condition": null},
    {"field_id": "environment_requests", "step": 5, "condition": null},
    {"field_id": "personal_interest", "step": 6, "condition": null},
    {"field_id": "social_capital", "step": 7, "condition": null},
    {"field_id": "format", "step": 8, "condition": null},
    {"field_id": "channels", "step": 9, "condition": null},
    {"field_id": "available_time", "step": 10, "condition": null},
    {"field_id": "priority", "step": 11, "condition": null},
    {"field_id": "target_margin", "step": 12, "condition": null},
    {"field_id": "operations_readiness", "step": 13, "condition": null},
    {"field_id": "ai_interest", "step": 14, "condition": null}
  ],
  "output_schema": {
    "version": "1.0",
    "artifact_type": "niche_table",
    "fields": ["niches", "recommendation", "recommended_niche", "action_plan_14_days", "red_flags"]
  },
  "project_fields_mapping": {
    "niche_candidates": "niches",
    "chosen_niche": "recommended_niche",
    "hypothesis_table": "niches[*].decomposition",
    "geography": "geography",
    "budget_range": "available_capital",
    "business_model": "format"
  },
  "test_cases": [
    {
      "input": {"geography": "Россия", "available_capital": "50–200 тыс.", "competencies": "маркетинг", "practical_experience": "5 лет в digital-маркетинге", "format": ["Товары"], "channels": ["Маркетплейсы"], "available_time": "20-40 ч/нед", "priority": "Баланс"},
      "expected_artifact_type": "niche_table",
      "expected_fields": ["niches", "recommendation", "recommended_niche"]
    }
  ]
}
